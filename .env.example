# ── Cloz Digital — Environment Variables ──
# Copy to .env for local development. In Railway, set these in the dashboard.

# ── Server ──
PORT=3000
NODE_ENV=production
ADMIN_PASSWORD=

# ── Persistent Storage ──
# Railway: set to a mounted volume path (e.g. /data)
# Local: leave unset to use project root
DATA_DIR=

# ── Cerebras AI Provider ──
CEREBRAS_API_KEY=

# ── Model Routing ──
# Default model (fallback for all groups)
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# Premium: complex business reasoning (lead analysis, package suggest, next actions)
CEREBRAS_PREMIUM_MODEL=qwen-3-235b-a22b-instruct-2507

# Fast: frequent operational responses (briefings, summaries, invoices)
CEREBRAS_FAST_MODEL=llama3.1-8b

# Scout: high-volume batch discovery
CEREBRAS_SCOUT_MODEL=llama3.1-8b

# Writing: persuasive client-facing content (outreach, proposals, blogs)
CEREBRAS_WRITING_MODEL=qwen-3-235b-a22b-instruct-2507

# Utility: simple text transformations (translate, rewrite, summarize)
CEREBRAS_UTILITY_MODEL=llama3.1-8b

# Review: complex website audits
CEREBRAS_REVIEW_MODEL=qwen-3-235b-a22b-instruct-2507

# Content: structured marketing output (instagram, captions)
CEREBRAS_CONTENT_MODEL=qwen-3-235b-a22b-instruct-2507

# Communication: client correspondence (emails, viber)
CEREBRAS_COMMUNICATION_MODEL=qwen-3-235b-a22b-instruct-2507

# Forecast: financial and business forecasting
CEREBRAS_FORECAST_MODEL=qwen-3-235b-a22b-instruct-2507
